# ============================================================
# AI 模型价格雷达 — 生产环境变量 (示例)
# ============================================================
# 复制此文件为 .env.production 并填写实际值:
#   cp .env.production.example .env.production

# ---- 数据库 ----
DATABASE_URL=postgresql://aileida:your-db-password@postgres:5432/aileida_radar
DB_PASSWORD=change-me-in-production

# ---- 应用 ----
APP_BASE_URL=https://aileida.example.com
NODE_ENV=production

# ---- 管理员 ----
ADMIN_PASSWORD=change-me-in-production

# ---- LLM (可选，用于新闻摘要和厂商分析) ----
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- 汇率 ----
USD_CNY_RATE=7.25

# ---- 数据源 ----
LITELLM_PRICES_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
OPENROUTER_API_URL=https://openrouter.ai/api/v1/models
LLM_PRICES_URL=https://raw.githubusercontent.com/simonw/llm-prices/main/current-v1.json
GENAI_PRICES_URL=https://raw.githubusercontent.com/pydantic/genai-prices/main/data.json

# ---- 抓取配置 ----
FETCH_TIMEOUT_MS=30000
FETCH_RETRY_COUNT=3
